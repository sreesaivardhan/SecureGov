# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Atlas → Connect → Drivers (Node.js) → copy connection string
# Replace <username>, <password>, <cluster-url>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/secureGovDocs?retryWrites=true&w=majority

# ─── Firebase Admin SDK — Production (Render) ────────────────────────────────
# Use these THREE env vars on Render / any cloud host.
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Open the downloaded JSON and copy the values below:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the full private key INCLUDING the -----BEGIN/END PRIVATE KEY----- lines.
# Render handles multi-line env vars correctly.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Firebase Admin SDK — Local Dev fallback ──────────────────────────────────
# If FIREBASE_PROJECT_ID is set, this is ignored.
# Otherwise, point to your downloaded serviceAccountKey.json (relative to server/)
FIREBASE_ADMIN_KEY_PATH=./serviceAccountKey.json

# ─── Firebase Storage ─────────────────────────────────────────────────────────
# Firebase Console → Storage → Files (shown at top as: gs://your-bucket-name)
# Use only the bucket name — NOT the gs:// prefix
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Localhost is automatically allowed in development — no need to list it.
# Production example:
CORS_ORIGIN=https://securegov.netlify.app

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Used to build invitation email links.
# MUST be your deployed Netlify URL in production — not localhost.
FRONTEND_URL=https://securegov.netlify.app

# ─── Email / Nodemailer ───────────────────────────────────────────────────────
# Without these, invitation links print to the server console (dev-safe fallback).
# Enable Gmail 2-Step Verification, then:
#   Google Account → Security → 2-Step Verification → App Passwords → generate
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=SecureGov <noreply@securegov.com>
